{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "300000"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "deny": [
      "Task(test-runner)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-completion.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/restore-experiment-logs.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/sync-experiment-logs.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 ~/.claude/statusline.py",
    "padding": 0
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "figma-security-guidance@figma-internal": true,
    "figma-plugin@figma-internal": true,
    "fix-a11y@figma-internal": true,
    "validate-and-fix@figma-internal": true,
    "feature-flag-cleanup@figma-internal": true,
    "qawolf-from-e2e@figma-internal": true,
    "ml-tools@figma-internal": true,
    "send-to-github@figma-internal": true,
    "prodsec@figma-internal": true,
    "testing@figma-internal": true,
    "ci-tools@figma-internal": true,
    "coder-tools@figma-internal": true,
    "update-dependency@figma-internal": true,
    "assistant-tooling@figma-internal": true,
    "refresh-plugins@figma-internal": true,
    "ml-experimenter@figma-internal": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "figma-internal": {
      "source": {
        "source": "directory",
        "path": "/home/ubuntu/figma/figma"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "promptSuggestionEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
